                  <Font name="System Bold" size="14.0" />
               </font>
            </TextField>
            <Button mnemonicParsing="false" onAction="#hesapla" prefHeight="50.0" prefWidth="100.0" style="-fx-background-radius: 50;" text="HESAPLA" textFill="#037ab5">
               <HBox.margin>
                  <Insets left="30.0" right="20.0" />
               </HBox.margin>
               <font>
                  <Font size="17.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </center>
</BorderPane>

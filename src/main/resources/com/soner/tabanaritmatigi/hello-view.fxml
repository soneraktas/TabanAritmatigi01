<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.soner.tabanaritmatigi.HelloController">
   <effect>
      <DropShadow />
   </effect>
   <top>
      <VBox alignment="CENTER" prefHeight="77.0" prefWidth="600.0" style="-fx-background-color: black;" BorderPane.alignment="CENTER">
         <children>
            <Label text="2 lik tabana çevrilmesi için 10 luk tabanda 0 ila 127 arasında bir sayı girin" textFill="#55bdf5">
               <font>
                  <Font size="17.0" />
               </font>
            </Label>
         </children>
      </VBox>
   </top>
   <bottom>
      <HBox alignment="BOTTOM_RIGHT" BorderPane.alignment="CENTER">
         <children>
            <ImageView fitHeight="225.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@tabanAritmatigi.png" />
               </image>
               <HBox.margin>
                  <Insets />
               </HBox.margin>
            </ImageView>
            <TilePane fx:id="ledPane" alignment="CENTER" hgap="15.0" prefHeight="200.0" prefWidth="470.0" vgap="10.0" />
         </children>
      </HBox>
   </bottom>
   <center>
      <HBox alignment="BOTTOM_RIGHT" BorderPane.alignment="CENTER">
         <children>
            <TextField fx:id="sayiTF" alignment="CENTER" prefHeight="50.0" prefWidth="200.0" promptText="10' LUK TABANDAKİ  SAYI" style="-fx-background-radius: 50;">
